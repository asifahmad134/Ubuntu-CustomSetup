{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#88c0d0",
          "style": "plain",
          "template": "<#5e81ac>┏[</>{{ .UserName }}<#5e81ac>]</>",
          "type": "session"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#b48ead",
          "template": "<#5e81ac>--[</>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}<#5e81ac>]</>",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "source": "cli",
            "mapped_branches": {
              "feat/*": "🚀 ",
              "bug/*": "🐛 "
            }
          }
        },
        {
          "foreground": "#b48ead",
          "style": "plain",
          "template": "<#5e81ac>--[</>{{.Profile}}{{if .Region}}@{{.Region}}{{end}}<#5e81ac>]</>",
          "type": "aws"
        },
        {
          "foreground": "#b48ead",
          "style": "plain",
          "template": "<#5e81ac>--[</>{{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}<#5e81ac>]</>",
          "type": "kubectl"
        },
        {
          "foreground": "#d8dee9",
          "style": "plain",
          "template": "<#5e81ac>[</><#5e81ac>]</>",
          "type": "root"
        },
        {
          "foreground": "#d8dee9",
          "style": "plain",
          "template": "<#5e81ac>[x</>{{ reason .Code }}<#5e81ac>]</>",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#88c0d0",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "<#5e81ac>┖[</>{{ .Path }}<#5e81ac>]</>",
          "type": "path"
        },
        {
          "foreground": "#ffffff",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#ADFF2F{{end}}",
            "{{if eq \"Discharging\" .State.String}}#FFFF00{{end}}",
            "{{if eq \"Full\" .State.String}}#66BB6A{{end}}"
          ],
          "properties": {
            "charged_icon": "<#ffffff></> ",
            "charging_icon": "󰚥 ",
            "discharging_icon": "<#ffff00></> "
          },
          "style": "powerline",
          "template": "[{{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}%]",
          "type": "battery"
        },
        {
          "type": "sysinfo",
          "foreground": "#ffffff",
          "template": "[ {{ round .PhysicalPercentUsed .Precision }}%]",
          "options": {
            "precision": 2
          },
          "style": "powerline"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#5e81ac",
          "style": "plain",
          "template": "  ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
