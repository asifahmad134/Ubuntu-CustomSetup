# git aliases
alias gl='git log --oneline --graph --decorate=full'
alias gss='git status -s'

# pnpm aliases
alias pd='pnpm run dev'


# lsd aliases
alias l1='lsd --tree --depth 1'
alias l2='lsd --tree --depth 2'
alias l3='lsd --tree --depth 3'
alias lf='lsd -AF'
alias lls='lsd -lF --total-size --group-directories-first'
alias lg='lsd -lFS --total-size --git --group-directories-first'
